{
  "manifest_version": 3,
  "name": "Jules Task Archiver",
  "version": "2.0.0",
  "description": "Archive completed Jules tasks for repos with no open GitHub PRs",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["https://jules.google.com/*", "https://api.github.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://jules.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
