const JULES_ORIGIN = 'https://jules.google.com'

function extractAccountNum(url) {
  const parts = new URL(url).pathname.split('/')
  const uIdx = parts.indexOf('u')
  return uIdx !== -1 && parts[uIdx + 1] ? parts[uIdx + 1] : '0'
}
