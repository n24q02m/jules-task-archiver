const JULES_ORIGIN = 'https://jules.google.com'
const ACCOUNT_RE = /\/u\/(\d+)/

function extractAccountNum(url) {
  try {
    const m = url.match(ACCOUNT_RE)
    return m ? m[1] : '0'
  } catch {
    return '0'
  }
}
