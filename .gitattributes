# Auto-detect text files and normalize line endings
* text=auto

# JavaScript
*.js text diff=javascript
*.mjs text diff=javascript

# Web
*.html text
*.css text
*.json text

# Config
*.toml text
*.yaml text
*.yml text
*.md text diff=markdown

# Shell
*.sh text eol=lf

# Binary
*.png binary
*.jpg binary
*.ico binary
